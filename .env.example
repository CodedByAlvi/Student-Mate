# GEMINI_API_KEY: Optional for the free-tier version.
# The app uses mock responses by default to avoid paid API costs.
# To enable real AI features, provide a valid Gemini API key.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
